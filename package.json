{
    "name": "daniels-server",
    "version": "1.0.0",
    "description": "A static file server",
    "license": "MIT",
    "author": "Daniel McGuire",
    "type": "module",
    "bin": {
        "daniels-server": "./dist/server.min.mjs"
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "files": [
        "dist/",
        "server-mimetypes.json"
    ],
    "imports": {
        "#server/primary": "./src/primary.mts",
        "#server/worker":  "./src/worker.mts",
        "#server/mimetypes": "./server-mimetypes.json"
    },
    "scripts": {
        "build": "tsc --noEmit && node build.mjs",
        "start": "node dist/server.min.mjs",
        "start-test": "node dist/server.min.mjs 80 ", 
        "dev": "node --watch src/server.mts"
    },
    "devDependencies": {
        "@types/node": "^25.0.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.0.0"
    }
}