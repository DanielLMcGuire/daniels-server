{
    "name": "daniels-server",
    "version": "1.0.0",
    "description": "A static http file server",
    "license": "MIT",
    "author": "Daniel McGuire",
    "type": "module",
    "bugs": {
        "url": "https://github.com/DanielLMcGuire/daniels-server/issues"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/DanielLMcGuire/daniels-server.git"
    },
    "bin": {
        "daniels-server": "./dist/server.min.mjs"
    },
    "exports": {
        ".": {
            "import": "./dist/api.min.mjs",
            "types": "./dist/api.d.mts"
        }
    },
    "engines": {
        "node": ">=22.0.0"
    },
    "files": [
        "dist/"
    ],
    "imports": {
        "#server/primary": "./src/primary.mts",
        "#server/worker": "./src/worker.mts",
        "#server/cache": "./src/cache.mts",
        "#server/serve": "./src/serve.mts",
        "#server/mime": "./src/mime.mts",
        "#server/range": "./src/range.mts",
        "#server/devtools": "./src/devtools.mts",
        "#server/types": "./src/types.mts",
        "#server/api": "./src/api.mts",
        "#server/mimetypes": "./resources/server-mimetypes.json"
    },
    "scripts": {
        "build": "node build.mjs",
        "start": "node dist/server.min.mjs",
        "dev": "node --watch src/server.mts"
    },
    "devDependencies": {
        "@types/node": "^25.0.0",
        "esbuild": "^0.25.0",
        "typescript": "^5.0.0"
    }
}
